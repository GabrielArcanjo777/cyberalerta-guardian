# Evolution API + PostgreSQL + Redis para DESENVOLVIMENTO LOCAL do CyberAlerta.
# Usado por docker-compose.evolution.yml (dev). Copie para `.env.evolution`.
# NUNCA versione `.env.evolution` com valores reais.
#
# Gere valores fortes:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# Chave de API da Evolution (obrigatória para parear/usar a instância).
EVOLUTION_API_KEY=

# Senha do Postgres local da Evolution (obrigatória).
POSTGRES_PASSWORD=
