NEXT_PUBLIC_API_URL=http://localhost:8000
APP_ENV=development
DRY_RUN=true
USE_LLM=false
LLM_PROVIDER=mock
STORAGE_BACKEND=memory
SQLITE_DATABASE_URL=sqlite:///./cyberalerta_guardian.db
STORE_FULL_MESSAGE=false
LOG_LEVEL=INFO
ENABLE_AUDIT_LOG=true
RISK_ENGINE_VERSION=v1
RULESET_VERSION=ruleset-local-v1
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_KEY=
CHANNEL_PROVIDER=twilio_sandbox
DUAL_BOT_CHANNEL_PROVIDER=mock_whatsapp
DUAL_BOT_GUARDIAN_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX
TWILIO_WEBHOOK_SECRET=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_GUARDIAN_TO=
TWILIO_VALIDATE_SIGNATURE=false
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_GUARDIAN_TO=
API_KEY_ENABLED=false
API_KEY_HEADER=X-CyberAlerta-API-Key
CYBERALERTA_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
N8N_ALLOWED_ORIGINS=http://localhost:5678
TRUSTED_WEBHOOK_IPS=
MAX_MESSAGE_LENGTH=4000
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
AUTH_SECRET_KEY=
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_NAME=cyberalerta_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_ENABLED=true
AUTH_REQUIRE_SENSITIVE_ROUTES=false
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_AUTH_ALLOWED_EMAILS=admin@example.com
GOOGLE_AUTH_ALLOWED_DOMAINS=
GOOGLE_AUTO_CREATE_USERS=false
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=
INITIAL_ADMIN_PASSWORD=
EVOLUTION_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_HEADER=X-N8N-CyberAlerta-Secret
N8N_BASE_URL=
N8N_DRY_RUN=true

# --- Beta real controlado ---
# Coloque seu numero real apenas no .env local, nunca no GitHub.
BETA_REAL_SEND_ENABLED=false
BETA_ALLOWED_RECIPIENTS=
BETA_REQUIRE_ALLOWED_RECIPIENT=true
