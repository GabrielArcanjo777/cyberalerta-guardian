# =============================================================================
# CyberAlerta Guardian — exemplo de variáveis de ambiente
# -----------------------------------------------------------------------------
# Copie para `.env` (backend) e preencha os valores locais.
# NUNCA versione o `.env` real, tokens, segredos, números reais ou bancos locais.
# =============================================================================

# --- Aplicação -------------------------------------------------------------
APP_ENV=development
DRY_RUN=true
LOG_LEVEL=INFO
RISK_ENGINE_VERSION=v1
RULESET_VERSION=ruleset-local-v1
ENABLE_AUDIT_LOG=true
MAX_MESSAGE_LENGTH=4000

# --- Storage local ---------------------------------------------------------
# memory = volátil (some no restart) | sqlite = persiste localmente
STORAGE_BACKEND=sqlite
SQLITE_DATABASE_URL=sqlite:///./cyberalerta_guardian.db
STORE_FULL_MESSAGE=false

# --- API key opcional (endpoints sensíveis) --------------------------------
API_KEY_ENABLED=false
API_KEY_HEADER=X-CyberAlerta-API-Key
CYBERALERTA_API_KEY=

# --- CORS ------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_BASE_URL=http://localhost:3000

# --- Rate limit ------------------------------------------------------------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
# IPs de proxy confiáveis (separados por vírgula). Só quando o request vem de um
# desses IPs o header X-Forwarded-For é usado para rate limit; caso contrário
# usa-se o IP direto da conexão (evita spoofing do limite de tentativas).
TRUSTED_WEBHOOK_IPS=

# --- Sessão / autenticação -------------------------------------------------
# Gere um valor forte: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Em produção é OBRIGATÓRIO definir (o backend recusa subir sem ela).
AUTH_SECRET_KEY=
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_NAME=cyberalerta_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_ENABLED=true
AUTH_REQUIRE_SENSITIVE_ROUTES=false

# --- Admin inicial (opcional, apenas dev) ----------------------------------
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=
INITIAL_ADMIN_PASSWORD=

# --- Google OAuth/OIDC (opcional) ------------------------------------------
# Desativado por padrão. Se ativar, use uma allowlist RESTRITA de e-mails.
# Não use um domínio público inteiro (ex.: gmail.com) com auto-create ligado.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_AUTO_CREATE_USERS=false
GOOGLE_AUTH_ALLOWED_EMAILS=admin@example.com
GOOGLE_AUTH_ALLOWED_DOMAINS=

# --- Canal WhatsApp: Evolution API -----------------------------------------
# Evolution API = WhatsApp Web via Baileys (NÃO oficial, gratuito, portfólio).
# Risco: possível ban do número; sessão pode cair e exigir novo pareamento QR.
# Não é produção. Suba a Evolution localmente (Docker) e pareie em /whatsapp-setup.
CHANNEL_PROVIDER=evolution
DUAL_BOT_CHANNEL_PROVIDER=evolution
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=guardian-demo
# Opcional em desenvolvimento; obrigatório em produção (sem ele o webhook responde 500).
EVOLUTION_WEBHOOK_SECRET=

# --- CONTATO DE CONFIANÇA (único destinatário que o bot pode contatar) -------
# O bot nunca responde ao remetente. O único envio possível é o alerta para
# este número, em qualquer canal. Vazio => alerta apenas simulado.
# Aliases legados aceitos como fallback: EVOLUTION_GUARDIAN_TO, DUAL_BOT_GUARDIAN_TO.
TRUSTED_CONTACT=

# --- PIPELINE HÍBRIDO (regras + LLM + Policy Engine) -------------------------
# Detecção híbrida: as regras determinísticas continuam; a LLM é apenas um
# insumo estruturado; SÓ a Policy Engine + o safety gate decidem envios.
# CONFIG PADRÃO SEGURA: desligada e em shadow (nunca envia por causa do híbrido).
#
#   HYBRID_LLM_ENABLED=false      -> liga a chamada à LLM
#   HYBRID_LLM_SHADOW_MODE=true   -> só grava a decisão; NÃO altera alertas
#
# Para observar sem risco: ENABLED=true + SHADOW_MODE=true (roda a LLM e grava a
# decisão que SERIA tomada, sem nunca enviar). Para produção real: SHADOW=false.
HYBRID_LLM_ENABLED=false
HYBRID_LLM_SHADOW_MODE=true
HYBRID_LLM_PROVIDER=openai_compatible
HYBRID_LLM_BASE_URL=
HYBRID_LLM_API_KEY=
HYBRID_LLM_MODEL=
HYBRID_LLM_TIMEOUT_SECONDS=12
HYBRID_LLM_MAX_RETRIES=1
HYBRID_LLM_TEMPERATURE=0
HYBRID_LLM_PROMPT_VERSION=v1
HYBRID_POLICY_VERSION=v1
# Se true e a LLM estiver indisponível, o máximo que a política decide é REVIEW.
HYBRID_REQUIRE_LLM_FOR_AUTO_ALERT=true
HYBRID_MAX_MESSAGE_CHARS=4000
# Redige cartão/CPF/telefone/código antes de enviar à LLM (mantém o sinal).
HYBRID_REDACT_PII=true

# --- Push notifications (FCM, opcional) -------------------------------------
# Sem os dois valores, o envio de push falha fechado (fcm_not_configured) em vez
# de fingir que entregou — só usados por POST /devices/{id}/test-push.
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# --- n8n (opcional; orquestração externa de canais) ------------------------
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_HEADER=X-N8N-CyberAlerta-Secret
N8N_BASE_URL=
N8N_ALLOWED_ORIGINS=http://localhost:5678
N8N_DRY_RUN=true
