# Dependencies
node_modules/
.venv/
venv/

# Build output
.next/
dist/
build/
frontend/tsconfig.tsbuildinfo

# Python
__pycache__/
*.pyc
.pytest_cache/

# Environment / secrets — never commit real values; use *.example as reference
.env
.env.*
!.env.example
!.env.*.example
frontend/.env.local
.n8n_cookie.txt

# Secret material — never commit
*.pem
*.key
credentials/
secrets/

# Backups & logs — never commit
backups/
logs/

# Runtime data (containers) — bind mounts if used; keep out of Git.
# NÃO ignorar backend/data inteiro: backend/data/scam_dataset_v1.jsonl é versionado.
runtime-data/
data/postgres/
data/redis/
data/evolution/
data/n8n/

# Local scratch / debug scripts — never commit
backend/debug_*.py
backend/test_send.py

# Local databases
*.db
*.sqlite
*.sqlite3

# Claude Code local config (agent settings, launch config) — do not commit
.claude/

# Playwright artifacts
frontend/test-results/
frontend/playwright-report/

# Coverage / OS
coverage/
.DS_Store

# Local editor extension packages
*.vsix

# Pre-codex backup snapshots (local only)
pre_codex_*.patch
pre_codex_*.txt
