# Dependencies
node_modules/
.venv/
venv/

# Build output
.next/
dist/
build/
frontend/tsconfig.tsbuildinfo

# Python
__pycache__/
*.pyc
.pytest_cache/

# Environment / secrets — never commit real values; use *.example as reference
.env
.env.*
!.env.example
!.env.*.example
frontend/.env.local
.n8n_cookie.txt

# Secret material — never commit
*.pem
*.key
credentials/
secrets/

# Backups & logs — never commit
backups/
logs/

# Runtime data (containers) — bind mounts if used; keep out of Git.
# NÃO ignorar backend/data inteiro: backend/data/scam_dataset_v1.jsonl é versionado.
runtime-data/
data/postgres/
data/redis/
data/evolution/
data/n8n/

# Local scratch / debug scripts — never commit
backend/debug_*.py
backend/test_send.py

# Local databases
*.db
*.sqlite
*.sqlite3

# Claude Code local config (agent settings, launch config) — do not commit
.claude/

# Playwright artifacts
frontend/test-results/
frontend/playwright-report/

# Coverage / OS
coverage/
.DS_Store

# Local editor extension packages
*.vsix

# Pre-codex backup snapshots (local only)
pre_codex_*.patch
pre_codex_*.txt

# Android Companion (apps/android-companion) — local/generated, never commit
apps/android-companion/**/build/
apps/android-companion/.gradle/
apps/android-companion/local.properties
apps/android-companion/**/google-services.json
*.jks
*.keystore
*.apk
*.aab

# Windows Shell (apps/windows-shell) — local/generated, never commit
frontend/out/
apps/windows-shell/src-tauri/target/
apps/windows-shell/src-tauri/gen/
*.pfx
*.p12
*.msix

# Session handoff notes (local only — may contain test credentials/paths)
HANDOFF_STATUS.md

# One-off manual test scripts with hardcoded local test credentials — never commit
backend/scripts/setup_mobile_test.py
