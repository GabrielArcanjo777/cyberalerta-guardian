# =============================================================================
# CyberAlerta Guardian — EXEMPLO de ambiente do n8n (profile OPCIONAL).
# Copie para `.env.n8n` e preencha. NUNCA versione `.env.n8n`.
# -----------------------------------------------------------------------------
# Só é lido quando o serviço n8n é ativado explicitamente:
#   docker compose --env-file .env.server -f compose.server.yml --profile n8n up -d
#
# O n8n NÃO publica porta. Acesse por túnel/porta local dedicada quando ligado.
# Sem segredos reais aqui: apenas placeholders.
# =============================================================================

# Chave de criptografia das credenciais do n8n (OBRIGATÓRIA para o n8n).
# Gere: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Se mudar depois, o n8n perde acesso às credenciais já salvas.
N8N_ENCRYPTION_KEY=

# Autenticação básica da UI do n8n (proteção mínima adicional).
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Host público do n8n quando exposto via túnel (sem barra final).
# Ex.: https://n8n.seu-dominio.exemplo
N8N_HOST=
N8N_PROTOCOL=https
WEBHOOK_URL=

# Segredo compartilhado com o backend para validar chamadas do n8n.
# (o backend lê N8N_WEBHOOK_SECRET do .env.server; use o MESMO valor)
N8N_WEBHOOK_SECRET=
