# =============================================================================
# CyberAlerta Guardian — EXEMPLO de ambiente de SERVIDOR (Linux + Cloudflare
# Tunnel). Copie para `.env.server` e preencha. NUNCA versione `.env.server`.
# -----------------------------------------------------------------------------
# Este arquivo NÃO contém segredos: apenas placeholders vazios e defaults
# seguros. Gere valores fortes conforme docs/server-deployment.md.
#
# Usado por: docker compose --env-file .env.server -f compose.server.yml ...
# =============================================================================

# --- Aplicação (produção → fail-fast liga automaticamente) -----------------
APP_ENV=production
DRY_RUN=true                     # NÃO envia de verdade. Manter true no início.
LOG_LEVEL=INFO
ENABLE_AUDIT_LOG=true
MAX_MESSAGE_LENGTH=4000

# --- Portas locais (somente 127.0.0.1 no host; alvo do Cloudflare Tunnel) --
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8000

# --- Frontend --------------------------------------------------------------
# URL PÚBLICA da API (o navegador acessa via túnel). Embutida no build do
# Next.js: trocar exige rebuild da imagem do frontend.
NEXT_PUBLIC_API_URL=https://api.seu-dominio.exemplo

# --- Storage do backend ----------------------------------------------------
# O backend usa SQLite em volume (/data). Postgres/Redis do compose atendem a
# Evolution (e a futura migração do backend, ver plano mestre). Não alterar
# para postgres sem suporte no código.
STORAGE_BACKEND=sqlite
SQLITE_DATABASE_URL=sqlite:////data/cyberalerta_guardian.db
STORE_FULL_MESSAGE=false         # Privacidade: nunca persistir mensagem completa.

# --- CORS / URLs -----------------------------------------------------------
# Troque pelos domínios reais do túnel (sem barra final).
ALLOWED_ORIGINS=https://app.seu-dominio.exemplo
FRONTEND_BASE_URL=https://app.seu-dominio.exemplo

# --- Rate limit (OBRIGATÓRIO true em produção) -----------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
# IPs de proxy confiáveis (o Cloudflare Tunnel entrega via loopback; ajuste se
# usar cabeçalhos de proxy). Vazio = usa o IP direto da conexão.
TRUSTED_WEBHOOK_IPS=

# --- Sessão / autenticação -------------------------------------------------
# OBRIGATÓRIO. Gere: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET_KEY=
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_NAME=cyberalerta_session
AUTH_COOKIE_SECURE=true           # Cookies só por HTTPS (túnel termina TLS).
AUTH_COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_ENABLED=true
AUTH_REQUIRE_SENSITIVE_ROUTES=true

# --- Admin inicial (opcional) ----------------------------------------------
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=
INITIAL_ADMIN_PASSWORD=

# --- Google OAuth/OIDC (opcional; allowlist RESTRITA se ativar) ------------
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.seu-dominio.exemplo/auth/google/callback
GOOGLE_AUTO_CREATE_USERS=false
GOOGLE_AUTH_ALLOWED_EMAILS=
GOOGLE_AUTH_ALLOWED_DOMAINS=

# --- Canal WhatsApp: Evolution API -----------------------------------------
CHANNEL_PROVIDER=evolution
DUAL_BOT_CHANNEL_PROVIDER=evolution
# Endereço interno (o compose sobrescreve para http://evolution:8080).
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_INSTANCE_NAME=guardian-demo
# OBRIGATÓRIOS. Gere: python -c "import secrets; print(secrets.token_urlsafe(32))"
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=

# --- Infra de dados (Postgres/Redis do compose) — OBRIGATÓRIOS -------------
POSTGRES_USER=evolution
POSTGRES_DB=evolution
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# --- CONTATO DE CONFIANÇA (único destinatário possível do alerta) ----------
# Vazio => alerta apenas simulado. O bot NUNCA responde ao remetente.
TRUSTED_CONTACT=
PROTECTED_PERSON_NUMBER=

# --- Envio real (mantenha DESLIGADO até o checklist de piloto) -------------
BETA_REAL_SEND_ENABLED=false
BETA_ALLOWED_RECIPIENTS=
BETA_REQUIRE_ALLOWED_RECIPIENT=true

# --- Pipeline híbrido (regras + LLM + Policy Engine) -----------------------
# Padrão seguro: LLM desligada e em shadow (nunca envia por causa do híbrido).
HYBRID_LLM_ENABLED=false
HYBRID_LLM_SHADOW_MODE=true
HYBRID_LLM_PROVIDER=openai_compatible
HYBRID_LLM_BASE_URL=
HYBRID_LLM_API_KEY=
HYBRID_LLM_MODEL=
HYBRID_LLM_TIMEOUT_SECONDS=12
HYBRID_LLM_MAX_RETRIES=1
HYBRID_LLM_TEMPERATURE=0
HYBRID_LLM_PROMPT_VERSION=v1
HYBRID_POLICY_VERSION=v1
HYBRID_REQUIRE_LLM_FOR_AUTO_ALERT=true
HYBRID_MAX_MESSAGE_CHARS=4000
HYBRID_REDACT_PII=true

# --- n8n (só quando o profile n8n estiver ativo; ver .env.n8n.example) ------
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_HEADER=X-N8N-CyberAlerta-Secret
N8N_BASE_URL=
N8N_ALLOWED_ORIGINS=
N8N_DRY_RUN=true
